# =============================================================================
# TracePilot - Environment Configuration
# =============================================================================

# Gemini API Key (required)
GEMINI_API_KEY=

# Arize Phoenix Cloud (required for strict end-to-end observability proof)
PHOENIX_API_KEY=
# Phoenix web/API host used by Phoenix MCP. Replace YOUR_SPACE before running
# smoke:phoenix:mcp or the strict broken-node demo. If this is empty, TracePilot
# smoke/demo scripts can derive the host from PHOENIX_BASE_URL or a Phoenix
# Cloud-style PHOENIX_COLLECTOR_ENDPOINT.
PHOENIX_HOST=https://app.phoenix.arize.com/s/YOUR_SPACE
# Phoenix web/API host used by Phoenix OTEL setup when collector endpoint is
# not provided. Keep aligned with PHOENIX_HOST for Phoenix Cloud.
PHOENIX_BASE_URL=https://app.phoenix.arize.com/s/YOUR_SPACE
# Optional OTLP collector endpoint. Leave empty to derive from PHOENIX_BASE_URL,
# or set the explicit endpoint provided by Phoenix. Phoenix Cloud base URLs are
# accepted by the smoke/demo scripts for MCP host resolution.
PHOENIX_COLLECTOR_ENDPOINT=
# Project name used for Phoenix OTEL spans and MCP smoke queries.
PHOENIX_PROJECT=tracepilot-gemini-cli
