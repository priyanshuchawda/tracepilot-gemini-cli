# =============================================================================
# TracePilot - Environment Configuration
# =============================================================================

# Gemini API Key (required)
GEMINI_API_KEY=

# Arize Phoenix Cloud (required for observability)
PHOENIX_API_KEY=
# Phoenix web/API host used by Phoenix MCP. Replace YOUR_SPACE with your
# actual Phoenix Cloud space path.
PHOENIX_HOST=https://app.phoenix.arize.com/s/YOUR_SPACE
# Phoenix web/API host used by Phoenix OTEL setup when collector endpoint is
# not provided. Keep aligned with PHOENIX_HOST for Phoenix Cloud.
PHOENIX_BASE_URL=https://app.phoenix.arize.com/s/YOUR_SPACE
# Optional OTLP collector endpoint. Leave empty to derive from PHOENIX_BASE_URL.
PHOENIX_COLLECTOR_ENDPOINT=
PHOENIX_PROJECT=tracepilot-gemini-cli
